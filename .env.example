# Bu dosyayı .env olarak kopyala ve gerçek değerlerle doldur
# DO NOT commit .env to git!

# Django secret key - production için güçlü bir key üret
SECRET_KEY=django-insecure-buraya-guclu-bir-key-gir

# Development: True, Production: False
DEBUG=False

# Virgülle ayrılmış izin verilen hostlar
# Railway için: your-app.railway.app,yourdomain.com
ALLOWED_HOSTS=your-app.railway.app,localhost,127.0.0.1

# Railway PostgreSQL bağlantısı (Railway otomatik sağlar)
# DATABASE_URL=postgresql://user:password@host:port/dbname
